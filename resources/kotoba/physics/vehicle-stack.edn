{:stack/id :kotoba/vehicle-physics
 :stack/version 1
 :document {:kind :vehicle
            :version 1
            :namespace kotoba.physics.vehicle
            :resource "kotoba/physics/vehicle-stack.edn"}

 :modules
 {:physics {:lib io.github.kotoba-lang/physics
            :workspace/path "."
            :role :contract
            :depends-on []}
  :realtime {:lib io.github.kotoba-lang/kami-vehicle
             :workspace/path "../kami-vehicle"
             :role :backend
             :backend :kotoba/kami-vehicle
             :depends-on [:physics]}
  :rom {:lib io.github.kotoba-lang/kami-engine-vphysics
        :workspace/path "../kami-engine-vphysics"
        :role :backend
        :backend :kotoba/vehicle-road-load-rom
        :depends-on [:physics]}
  :vehicle-scene {:lib io.github.kotoba-lang/kami-vehicle-scene
                  :workspace/path "../kami-vehicle-scene"
                  :role :authoring
                  :depends-on [:physics :realtime]}
  :modeler {:lib io.github.kotoba-lang/kami-app-modeler
            :workspace/path "../kami-app-modeler"
            :role :authoring
            :depends-on [:physics]}
  :vehicle-designer {:lib io.github.kotoba-lang/kami-engine-vehicle-designer
                     :workspace/path "../kami-engine-vehicle-designer"
                     :role :design
                     :depends-on [:physics :rom]}
  :drive {:lib gftdcojp/network-isekai
          :workspace/path "../../gftdcojp/network-isekai"
          :role :runtime-consumer
          :depends-on [:physics :realtime]}
  :studio {:lib io.github.kotoba-lang/kami-studio
           :workspace/path "../kami-studio"
           :role :workspace-index
           :depends-on []
           :architecture-only-depends-on [:modeler]}}

 :selection
 {:realtime {:backend :kotoba/kami-vehicle
             :fidelity :realtime}
  :design {:backend :kotoba/vehicle-road-load-rom
           :fidelity :reduced-order}}

 :policy
 {:dependency-source :deps.edn
  :architecture-source "kotoba/physics/vehicle-stack.edn"
  :workspace-resolution :local/root
  :release-resolution :git/sha
  :direct-require-must-be-direct-dependency true}}
